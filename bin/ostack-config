#!/usr/bin/env bash
# ostack-config — read/write ~/.ostack/config.yaml
#
# Usage:
#   ostack-config get <key>          — read a config value
#   ostack-config set <key> <value>  — write a config value
#   ostack-config list               — show all config
#
# Env overrides (for testing):
#   OSTACK_STATE_DIR  — override ~/.ostack state directory
set -euo pipefail

STATE_DIR="${OSTACK_STATE_DIR:-$HOME/.ostack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: ostack-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: ostack-config set <key> <value>}"
    VALUE="${3:?Usage: ostack-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    TMP_FILE="$(mktemp "${STATE_DIR}/config.XXXXXX")"
    if [ -f "$CONFIG_FILE" ]; then
      awk -v key="$KEY" -v value="$VALUE" '
        BEGIN { replaced = 0 }
        $0 ~ ("^" key ":") {
          print key ": " value
          replaced = 1
          next
        }
        { print }
        END {
          if (!replaced) print key ": " value
        }
      ' "$CONFIG_FILE" > "$TMP_FILE"
    else
      printf "%s: %s\n" "$KEY" "$VALUE" > "$TMP_FILE"
    fi
    mv "$TMP_FILE" "$CONFIG_FILE"
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: ostack-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
